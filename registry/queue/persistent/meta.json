{
  "name": "queue-persistent",
  "category": "queue",
  "description": "SQLite-backed persistent queue. Survives restarts. At-least-once delivery. Retry with backoff.",
  "npmDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "suggests": [],
  "suggestReason": {},
  "configSchema": {
    "dbPath": { "type": "string", "default": ".clawkit/queue.db" },
    "maxRetries": { "type": "number", "default": 3 },
    "concurrency": { "type": "number", "default": 1 }
  },
  "importName": "createPersistentQueue",
  "instanceTemplate": "createPersistentQueue(config.queue ?? { name: \"queue-persistent\" })",
  "phase": 6
}
