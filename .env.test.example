# ClawKit — Test Environment Variables
# Copy to .env.test and fill in the keys you have.
# Agent smoke tests will skip automatically for missing keys.

# === Agents ===

# Anthropic (minimal, webchat-demo, webhook-api, full-stack presets)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (openai-full preset, also used by agent-generic-openai)
OPENAI_API_KEY=sk-...

# Google Gemini (gemini-starter preset)
GOOGLE_API_KEY=AIza...

# DeepSeek (deepseek-coder preset)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (openrouter-multi preset)
OPENROUTER_API_KEY=sk-or-...

# AWS Bedrock (enterprise-aws preset)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Ollama — no key needed, just run: ollama serve
# Tests check localhost:11434 automatically

# === Channels (token-gated, not used in smoke tests) ===

# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# DISCORD_TOKEN=...
# TELEGRAM_BOT_TOKEN=...
# WHATSAPP_TOKEN=...
# WHATSAPP_PHONE_ID=...
